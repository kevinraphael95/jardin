<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jardin Ghibli</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0d1b2a;display:flex;justify-content:center;align-items:center;min-height:100vh;overflow:hidden;font-family:'Georgia',serif}
#game-container{width:100vw;height:100vh;position:relative;overflow:hidden}
canvas{display:block;width:100%;height:100%}
.ui{position:absolute;top:24px;left:24px;display:flex;flex-direction:column;gap:12px;z-index:100}
.btn{width:52px;height:52px;border-radius:50%;border:2px solid rgba(255,255,255,0.6);background:rgba(255,255,255,0.15);font-size:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.25s;backdrop-filter:blur(8px);box-shadow:0 2px 12px rgba(0,0,0,0.3)}
.btn:hover{transform:scale(1.12);background:rgba(255,255,255,0.28)}
.btn.active{background:rgba(255,220,100,0.35);border-color:rgba(255,210,80,0.9);box-shadow:0 0 18px rgba(255,200,60,0.5)}
.hud{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.45);color:rgba(255,255,255,0.85);padding:9px 22px;border-radius:50px;font-size:12px;pointer-events:none;backdrop-filter:blur(10px);z-index:100;letter-spacing:.06em;border:1px solid rgba(255,255,255,0.1)}
kbd{background:rgba(255,255,255,0.15);padding:2px 7px;border-radius:4px;font-family:monospace;color:#ffd87a;margin:0 2px}
#season-btn{position:absolute;top:24px;right:24px;background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.4);border-radius:50px;color:rgba(255,255,255,0.9);padding:8px 16px;font-size:12px;cursor:pointer;backdrop-filter:blur(8px);letter-spacing:.08em;transition:all .2s;z-index:100}
#season-btn:hover{background:rgba(255,255,255,0.25)}
</style>
</head>
<body>
<div id="game-container">
  <canvas id="canvas"></canvas>
  <div class="ui">
    <div class="btn active" id="btn-plant" title="Planter" onclick="setTool('plant')">🌱</div>
    <div class="btn" id="btn-cut" title="Couper" onclick="setTool('cut')">✂️</div>
    <div class="btn" id="btn-water" title="Arroser" onclick="setTool('water')">💧</div>
  </div>
  <button id="season-btn" onclick="nextSeason()">SAISON ▸</button>
  <div class="hud"><kbd>ZQSD</kbd> Déplacer &nbsp;|&nbsp; <kbd>Clic</kbd> Action</div>
</div>
<script>
const container = document.getElementById('game-container');
const canvas    = document.getElementById('canvas');
const ctx       = canvas.getContext('2d');

let w, h, time = 0, wind = 0;
let tool = 'plant';
let flowers = [], particles = [], waterDrops = [], clouds = [], birds = [], fireflies = [];
let seasonIdx = 0;
const SEASONS = ['printemps','été','automne','hiver'];

// ── Palettes par saison ──
const SEASON_CFG = {
  printemps: {
    skyTop:'#6ab4e8', skyBot:'#c8eac0',
    groundBase:'hsl(115,{s}%,{l}%)', groundS:30, groundL:20,
    fogColor:'rgba(200,240,210,',
    sunColor:'#fffde0', sunGlow:'rgba(255,245,180,0.3)',
    treeTrunk:'#5a3a1a', treeLeaf:'#4a9a3a',
    flowerPalettes:[
      {main:'#ff6b9d',center:'#fff176',stem:'#2ecc71',leaf:'#27ae60'},
      {main:'#ff9ff3',center:'#feca57',stem:'#27ae60',leaf:'#229954'},
      {main:'#74b9ff',center:'#fdcb6e',stem:'#00b894',leaf:'#1e8449'},
      {main:'#ffeaa7',center:'#e17055',stem:'#00cec9',leaf:'#00b894'},
      {main:'#fd79a8',center:'#ffeaa7',stem:'#6c5ce7',leaf:'#00b894'},
      {main:'#a29bfe',center:'#fd79a8',stem:'#55efc4',leaf:'#00cec9'},
    ]
  },
  été: {
    skyTop:'#1a78c2', skyBot:'#8ed1e8',
    groundBase:'hsl(110,{s}%,{l}%)', groundS:28, groundL:18,
    fogColor:'rgba(180,220,255,',
    sunColor:'#fff9a0', sunGlow:'rgba(255,240,100,0.45)',
    treeTrunk:'#4a2e10', treeLeaf:'#2d7a25',
    flowerPalettes:[
      {main:'#fdcb6e',center:'#e17055',stem:'#00b894',leaf:'#006647'},
      {main:'#e17055',center:'#ffeaa7',stem:'#00cec9',leaf:'#005f3f'},
      {main:'#ff7675',center:'#fff',stem:'#26de81',leaf:'#20bf6b'},
      {main:'#ffeaa7',center:'#fdcb6e',stem:'#2ecc71',leaf:'#27ae60'},
      {main:'#fd79a8',center:'#fff',stem:'#0be881',leaf:'#05c46b'},
    ]
  },
  automne: {
    skyTop:'#6e3b0a', skyBot:'#e8b56a',
    groundBase:'hsl(30,{s}%,{l}%)', groundS:25, groundL:18,
    fogColor:'rgba(220,160,80,',
    sunColor:'#ffcc80', sunGlow:'rgba(255,160,60,0.35)',
    treeTrunk:'#3e2008', treeLeaf:'#c0580a',
    flowerPalettes:[
      {main:'#e17055',center:'#fdcb6e',stem:'#a0522d',leaf:'#8b4513'},
      {main:'#fd79a8',center:'#fff',stem:'#cd853f',leaf:'#8b6914'},
      {main:'#fdcb6e',center:'#e17055',stem:'#b8860b',leaf:'#8b6914'},
      {main:'#d63031',center:'#ffeaa7',stem:'#a0522d',leaf:'#8b4513'},
    ]
  },
  hiver: {
    skyTop:'#1a2a4a', skyBot:'#8ab4d4',
    groundBase:'hsl(210,{s}%,{l}%)', groundS:15, groundL:60,
    fogColor:'rgba(200,220,255,',
    sunColor:'#e0f0ff', sunGlow:'rgba(180,210,255,0.25)',
    treeTrunk:'#3a3a4a', treeLeaf:'#405070',
    flowerPalettes:[
      {main:'#dfe6e9',center:'#b2bec3',stem:'#636e72',leaf:'#2d3436'},
      {main:'#a29bfe',center:'#dfe6e9',stem:'#6c5ce7',leaf:'#4a4a6a'},
      {main:'#74b9ff',center:'#fff',stem:'#0984e3',leaf:'#2d6eaa'},
    ]
  }
};

const player = {
  x:0,y:0,vx:0,vy:0,speed:4.5,friction:0.80,
  dir:1,isMoving:false,frame:0,frameTimer:0,
  trail:[]
};
const keys = {};
window.addEventListener('keydown', e => { keys[e.code] = true; e.preventDefault(); });
window.addEventListener('keyup',   e => keys[e.code] = false);

function setTool(t) {
  tool = t;
  ['plant','cut','water'].forEach(x => document.getElementById('btn-'+x).classList.toggle('active', x===t));
  container.style.cursor = t === 'cut' ? 'none' : 'crosshair';
}
function nextSeason() {
  seasonIdx = (seasonIdx+1)%4;
  const s = SEASONS[seasonIdx];
  document.getElementById('season-btn').textContent = s.toUpperCase()+' ▸';
  spawnSeasonParticles();
}

// ── Perspective ──
const ROWS = 14;
const HORIZON_RATIO = 0.38;
const getHorizon = () => h * HORIZON_RATIO;
const getY       = r  => getHorizon() + (r / ROWS) * (h - getHorizon());
const getScale   = y  => 0.18 + 0.82 * ((y - getHorizon()) / (h - getHorizon()));
const getRow     = y  => Math.floor(((y - getHorizon()) / (h - getHorizon())) * ROWS);

let blades = [], trees = [];

function init() {
  w = canvas.width  = window.innerWidth;
  h = canvas.height = window.innerHeight;
  player.x = w/2; player.y = h*0.68;
  buildGrass();
  buildTrees();
  buildClouds();
  buildBirds();
  buildFireflies();
}

function buildGrass() {
  blades = [];
  for (let r=0; r<ROWS; r++) {
    const rowY = getY(r);
    const sc   = getScale(rowY);
    const n    = Math.floor((w/2.2) * (0.5+sc));
    for (let i=0; i<n; i++) {
      const hue = 95 + Math.random()*35 + (seasonIdx===2?-30:0) + (seasonIdx===3?-55:0);
      const sat = seasonIdx===3 ? 8  : 32 + r*2;
      const lig = seasonIdx===3 ? 72 : 18 + r*2;
      blades.push({
        x:Math.random()*w, row:r,
        y:rowY+(Math.random()*18-9),
        sc, h:(22+Math.random()*32)*sc,
        w:(1.2+Math.random()*2.2)*sc,
        offset:Math.random()*Math.PI*2,
        color:`hsl(${hue},${sat}%,${lig}%)`
      });
    }
  }
}

function buildTrees() {
  trees = [];
  const cfg = SEASON_CFG[SEASONS[seasonIdx]];
  const count = 6 + Math.floor(Math.random()*5);
  for (let i=0; i<count; i++) {
    const row = Math.floor(Math.random()*4);
    const rowY = getY(row);
    const sc   = getScale(rowY)*1.4;
    trees.push({
      x:Math.random()*w, y:rowY, row, sc,
      trunkH:(60+Math.random()*40)*sc,
      crownR:(45+Math.random()*35)*sc,
      trunk:cfg.treeTrunk, leaf:cfg.treeLeaf,
      sway:Math.random()*Math.PI*2,
      variant:Math.random()>0.5?'round':'conical'
    });
  }
  trees.sort((a,b)=>a.y-b.y);
}

function buildClouds() {
  clouds = [];
  for (let i=0; i<7; i++) {
    clouds.push({
      x:Math.random()*w, y:h*(0.05+Math.random()*0.28),
      r:40+Math.random()*60, speed:0.12+Math.random()*0.2,
      alpha:0.55+Math.random()*0.3
    });
  }
}

function buildBirds() {
  birds = [];
  for (let i=0; i<5; i++) {
    birds.push({
      x:Math.random()*w, y:h*(0.05+Math.random()*0.25),
      vx:0.6+Math.random()*0.8, vy:0,
      wing:0, wingDir:1, scale:0.6+Math.random()*0.5
    });
  }
}

function buildFireflies() {
  fireflies = [];
  for (let i=0; i<30; i++) {
    fireflies.push({
      x:Math.random()*w, y:h*(0.45+Math.random()*0.5),
      ox:Math.random()*w, oy:h*(0.45+Math.random()*0.5),
      r:1+Math.random()*1.5,
      phase:Math.random()*Math.PI*2,
      speed:0.3+Math.random()*0.5
    });
  }
}

function spawnSeasonParticles() {
  for (let i=0; i<60; i++) {
    particles.push({
      x:Math.random()*w, y:Math.random()*h*0.5,
      vx:(Math.random()-0.5)*2, vy:0.4+Math.random()*1.2,
      alpha:1, size:3+Math.random()*6,
      color: seasonIdx===3 ? '#e0f0ff' :
             seasonIdx===2 ? `hsl(${20+Math.random()*40},80%,55%)` :
             `hsl(${80+Math.random()*120},70%,60%)`,
      rot:Math.random()*Math.PI*2, rotV:(Math.random()-0.5)*0.1,
      life:1
    });
  }
}

function createFlower(x, y) {
  const row = getRow(y);
  if (row<0||row>=ROWS) return;
  const sc  = getScale(y);
  const cfg = SEASON_CFG[SEASONS[seasonIdx]];
  const pal = cfg.flowerPalettes[Math.floor(Math.random()*cfg.flowerPalettes.length)];
  flowers.push({
    x,y,row,sc,h:0,
    maxH:(55+Math.random()*45)*sc,
    pal, petals:5+Math.floor(Math.random()*4),
    size:(8+Math.random()*8)*sc,
    seed:Math.random()*100,
    wilt:0, watered:0,
    type: Math.random()>0.5 ? 'daisy':'tulip',
    leafAngle:(Math.random()-0.5)*0.6
  });
  flowers.sort((a,b)=>a.y-b.y);
  // spawn soil particles
  for (let i=0;i<8;i++) particles.push({
    x,y,vx:(Math.random()-0.5)*3,vy:-(Math.random()*2),
    alpha:1,size:2+Math.random()*3,
    color:`hsl(25,${30+Math.random()*20}%,${20+Math.random()*15}%)`,
    rot:0,rotV:0,life:1
  });
}

// ── Dessin soleil ──
function drawSun(cfg) {
  const sx=w*0.82, sy=h*0.1, sr=35;
  const grd=ctx.createRadialGradient(sx,sy,0,sx,sy,sr*3.5);
  grd.addColorStop(0,cfg.sunColor);
  grd.addColorStop(0.25,cfg.sunGlow);
  grd.addColorStop(1,'rgba(255,255,255,0)');
  ctx.fillStyle=grd; ctx.beginPath(); ctx.arc(sx,sy,sr*3.5,0,Math.PI*2); ctx.fill();
  ctx.fillStyle=cfg.sunColor; ctx.beginPath(); ctx.arc(sx,sy,sr,0,Math.PI*2); ctx.fill();
}

// ── Dessin nuages ──
function drawCloud(c) {
  ctx.save();
  ctx.globalAlpha=c.alpha;
  ctx.fillStyle='rgba(255,255,255,0.92)';
  const puffs=[{dx:0,dy:0,r:c.r},{dx:c.r*.7,dy:c.r*.15,r:c.r*.75},{dx:-c.r*.65,dy:c.r*.2,r:c.r*.65},{dx:c.r*.35,dy:-c.r*.3,r:c.r*.6}];
  puffs.forEach(p=>{
    ctx.beginPath(); ctx.arc(c.x+p.dx,c.y+p.dy,p.r,0,Math.PI*2); ctx.fill();
  });
  ctx.restore();
}

// ── Dessin arbre ──
function drawTree(t, cfg) {
  const sway = Math.sin(time*0.7+t.sway)*0.04*t.sc;
  ctx.save();
  ctx.translate(t.x, t.y);
  // Ombre
  ctx.fillStyle='rgba(0,0,0,0.12)';
  ctx.beginPath(); ctx.ellipse(0,2,t.crownR*0.7,t.crownR*0.18,0,0,Math.PI*2); ctx.fill();
  // Tronc
  ctx.fillStyle=cfg.treeTrunk;
  ctx.beginPath(); ctx.roundRect(-5*t.sc,0,10*t.sc,-t.trunkH,[2,2,0,0]); ctx.fill();
  // Feuillage
  ctx.rotate(sway);
  if (t.variant==='conical') {
    // sapin
    [[1.0,1.0],[0.8,0.6],[0.6,0.3]].forEach(([rs,ys])=>{
      const g=ctx.createRadialGradient(0,-t.trunkH*ys,0,0,-t.trunkH*ys,t.crownR*rs);
      g.addColorStop(0,adjustColor(cfg.treeLeaf,20));
      g.addColorStop(1,cfg.treeLeaf);
      ctx.fillStyle=g;
      ctx.beginPath();
      ctx.moveTo(-t.crownR*rs,-t.trunkH*(ys-0.35));
      ctx.lineTo(0,-t.trunkH*(ys+0.35));
      ctx.lineTo(t.crownR*rs,-t.trunkH*(ys-0.35));
      ctx.closePath(); ctx.fill();
    });
  } else {
    // feuillus — 3 cercles superposés
    [[-t.crownR*0.3,-t.trunkH-t.crownR*0.2,t.crownR*0.75],
     [t.crownR*0.25,-t.trunkH-t.crownR*0.1,t.crownR*0.7],
     [0,-t.trunkH,t.crownR]].forEach(([ox,oy,r])=>{
      const g=ctx.createRadialGradient(ox,oy,0,ox,oy,r);
      g.addColorStop(0,adjustColor(cfg.treeLeaf,25));
      g.addColorStop(1,cfg.treeLeaf);
      ctx.fillStyle=g; ctx.beginPath(); ctx.arc(ox,oy,r,0,Math.PI*2); ctx.fill();
    });
  }
  // Automne — feuilles tombantes du tronc
  if (seasonIdx===2 && Math.random()<0.004) {
    particles.push({
      x:t.x+(Math.random()-0.5)*t.crownR, y:t.y-t.trunkH,
      vx:(Math.random()-0.5)*1.5, vy:0.3+Math.random()*0.5,
      alpha:1,size:4+Math.random()*4,
      color:`hsl(${15+Math.random()*40},80%,50%)`,
      rot:Math.random()*Math.PI*2,rotV:(Math.random()-0.5)*0.12,life:1
    });
  }
  ctx.restore();
}

function adjustColor(hex, amount) {
  // Éclaircit légèrement une couleur CSS
  return hex; // simplifié — on garde la couleur brute pour les gradients
}

// ── Dessin fleur ultra-détaillé ──
function drawFlower(f) {
  if (f.h < f.maxH) f.h = Math.min(f.maxH, f.h + (1.8 - f.wilt*0.5));
  if (f.watered>0) { f.watered--; if(f.wilt>0) f.wilt=Math.max(0,f.wilt-0.01); }
  const sway = Math.sin(time*1.1+f.seed)*7*f.sc + wind*20*f.sc;
  const wiltAngle = f.wilt * 0.5;
  const tx = f.x + sway;
  const ty = f.y - f.h;

  // Ombre fleur
  ctx.save();
  ctx.globalAlpha=0.1;
  ctx.fillStyle='#000';
  ctx.beginPath(); ctx.ellipse(f.x+2, f.y, 8*f.sc, 3*f.sc, 0, 0, Math.PI*2); ctx.fill();
  ctx.restore();

  // Tige — courbe de Bézier naturelle
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(f.x, f.y);
  const cpx = f.x + sway*0.4 + wind*4;
  const cpy = f.y - f.h*0.55;
  ctx.quadraticCurveTo(cpx, cpy, tx, ty);
  const grad=ctx.createLinearGradient(f.x,f.y,tx,ty);
  grad.addColorStop(0, f.pal.stem);
  grad.addColorStop(1, adjustLightness(f.pal.stem, 1.2));
  ctx.strokeStyle=grad;
  ctx.lineWidth=3.2*f.sc*(1-f.wilt*0.3);
  ctx.lineCap='round'; ctx.stroke();

  // Feuilles
  [0.35, 0.65].forEach((t2,i) => {
    const lx = f.x + (tx-f.x)*t2 + sway*t2;
    const ly = f.y - f.h*t2;
    const angle = (i===0?1:-1)*(0.9+f.leafAngle) + wiltAngle*0.3;
    const ls = (14+Math.random()*0)*f.sc;
    ctx.save();
    ctx.translate(lx,ly);
    ctx.rotate(angle);
    const lg=ctx.createLinearGradient(0,0,ls,0);
    lg.addColorStop(0,f.pal.leaf||f.pal.stem);
    lg.addColorStop(1,adjustLightness(f.pal.leaf||f.pal.stem,1.3));
    ctx.fillStyle=lg;
    ctx.beginPath();
    ctx.moveTo(0,0);
    ctx.quadraticCurveTo(ls*0.5,-ls*0.4,ls*1.1,0);
    ctx.quadraticCurveTo(ls*0.5,ls*0.4,0,0);
    ctx.fill();
    ctx.restore();
  });

  // Tête de fleur
  ctx.save();
  ctx.translate(tx, ty);
  ctx.rotate(time*0.35+f.seed + wiltAngle);

  if (f.type==='daisy') {
    // Pétales allongés — style marguerite réaliste
    for (let i=0;i<f.petals;i++) {
      const ang = (Math.PI*2/f.petals)*i;
      ctx.save();
      ctx.rotate(ang);
      // Gradient sur chaque pétale
      const pg=ctx.createLinearGradient(0,0,0,-f.size*1.8);
      pg.addColorStop(0,f.pal.main);
      pg.addColorStop(0.5,adjustLightness(f.pal.main,1.3));
      pg.addColorStop(1,'rgba(255,255,255,0.4)');
      ctx.fillStyle=pg;
      ctx.beginPath();
      ctx.ellipse(0,-f.size*1.0,f.size*0.32,f.size*0.9,0,0,Math.PI*2);
      ctx.fill();
      // Nervure centrale
      ctx.strokeStyle='rgba(255,255,255,0.25)';
      ctx.lineWidth=0.7*f.sc;
      ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(0,-f.size*1.7); ctx.stroke();
      ctx.restore();
    }
    // Cœur — deux couches
    const cg=ctx.createRadialGradient(0,0,0,0,0,f.size*0.55);
    cg.addColorStop(0,adjustLightness(f.pal.center,1.3));
    cg.addColorStop(1,f.pal.center);
    ctx.fillStyle=cg;
    ctx.beginPath(); ctx.arc(0,0,f.size*0.55,0,Math.PI*2); ctx.fill();
    // Texture pointillée du cœur
    ctx.fillStyle='rgba(0,0,0,0.12)';
    for (let i=0;i<8;i++) {
      const a=Math.random()*Math.PI*2, r2=Math.random()*f.size*0.45;
      ctx.beginPath(); ctx.arc(Math.cos(a)*r2,Math.sin(a)*r2,0.8*f.sc,0,Math.PI*2); ctx.fill();
    }
  } else {
    // Tulipe — pétales en coupe
    for (let i=0;i<f.petals;i++) {
      const ang = (Math.PI*2/f.petals)*i;
      ctx.save(); ctx.rotate(ang);
      const pg=ctx.createLinearGradient(0,0,0,-f.size*1.5);
      pg.addColorStop(0,adjustLightness(f.pal.main,0.8));
      pg.addColorStop(1,f.pal.main);
      ctx.fillStyle=pg;
      ctx.beginPath();
      ctx.moveTo(0,0);
      ctx.bezierCurveTo(-f.size*0.5,-f.size*0.6,-f.size*0.6,-f.size*1.2,0,-f.size*1.5);
      ctx.bezierCurveTo(f.size*0.6,-f.size*1.2,f.size*0.5,-f.size*0.6,0,0);
      ctx.fill();
      ctx.restore();
    }
    // Étamines
    ctx.fillStyle=f.pal.center;
    ctx.beginPath(); ctx.arc(0,0,f.size*0.3,0,Math.PI*2); ctx.fill();
    for(let i=0;i<5;i++){
      const a=(Math.PI*2/5)*i;
      ctx.fillStyle='rgba(255,255,255,0.7)';
      ctx.beginPath(); ctx.arc(Math.cos(a)*f.size*0.18,Math.sin(a)*f.size*0.18,1.2*f.sc,0,Math.PI*2); ctx.fill();
    }
  }
  ctx.restore();
  ctx.restore();

  // Gouttes d'eau si arrosé
  if(f.watered>20){
    for(let i=0;i<2;i++){
      if(Math.random()<0.3) waterDrops.push({
        x:tx+(Math.random()-0.5)*10*f.sc,y:ty,
        vy:0.5+Math.random()*1.2,alpha:0.8,
        r:1.5*f.sc
      });
    }
  }
}

function adjustLightness(color, factor) {
  // Retourne la même couleur si pas un format simple — fallback safe
  return color;
}

// ── Personnage ghibli ──
function drawPlayer(sc) {
  const bounce = player.isMoving ? Math.abs(Math.sin(time*11))*8*sc : 0;
  ctx.save();
  ctx.translate(player.x, player.y-bounce);
  ctx.scale(player.dir*sc, sc);

  // Ombre
  ctx.fillStyle='rgba(0,0,0,0.18)';
  ctx.beginPath(); ctx.ellipse(0,5,20,7,0,0,Math.PI*2); ctx.fill();

  // Cape / corps arrière
  ctx.fillStyle='#5d4e8c';
  ctx.beginPath(); ctx.roundRect(-18,-28,36,30,[2,2,14,14]); ctx.fill();

  // Robe / corps
  ctx.fillStyle='#7c6aad';
  ctx.beginPath(); ctx.roundRect(-15,-30,30,28,[2,2,12,12]); ctx.fill();
  // Détails vêtement
  ctx.fillStyle='rgba(255,255,255,0.12)';
  ctx.beginPath(); ctx.roundRect(-3,-30,6,28,[1]); ctx.fill();

  // Cou
  ctx.fillStyle='#f5c9a0';
  ctx.beginPath(); ctx.roundRect(-5,-38,10,12,[3]); ctx.fill();

  // Tête
  ctx.fillStyle='#f5c9a0';
  ctx.beginPath(); ctx.ellipse(0,-54,18,20,0,0,Math.PI*2); ctx.fill();

  // Cheveux — style ghibli
  ctx.fillStyle='#2c1a0e';
  ctx.beginPath();
  ctx.ellipse(0,-68,20,14,0,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(-18,-58,8,12,0.4,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(18,-58,8,12,-0.4,0,Math.PI*2); ctx.fill();

  // Yeux grands style ghibli
  const eyeY=-55;
  [[-7,eyeY],[7,eyeY]].forEach(([ex,ey])=>{
    // Blanc
    ctx.fillStyle='#fff';
    ctx.beginPath(); ctx.ellipse(ex,ey,4.5,5,0,0,Math.PI*2); ctx.fill();
    // Iris
    ctx.fillStyle='#2c5f8a';
    ctx.beginPath(); ctx.ellipse(ex,ey,3.5,4,0,0,Math.PI*2); ctx.fill();
    // Pupille
    ctx.fillStyle='#111';
    ctx.beginPath(); ctx.arc(ex,ey,2,0,Math.PI*2); ctx.fill();
    // Reflet
    ctx.fillStyle='rgba(255,255,255,0.85)';
    ctx.beginPath(); ctx.arc(ex+1.5,ey-1.5,1.2,0,Math.PI*2); ctx.fill();
  });

  // Joues
  ctx.globalAlpha=0.35;
  ctx.fillStyle='#ff9a9a';
  ctx.beginPath(); ctx.arc(-13,-52,4.5,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(13,-52,4.5,0,Math.PI*2); ctx.fill();
  ctx.globalAlpha=1;

  // Bouche
  ctx.strokeStyle='rgba(180,80,80,0.6)';
  ctx.lineWidth=1.2;
  ctx.beginPath(); ctx.arc(0,-46,3,0.2,Math.PI-0.2); ctx.stroke();

  // Bras avec outil
  const armSwing = player.isMoving ? Math.sin(time*10)*0.3 : 0;
  ctx.fillStyle='#7c6aad';
  ctx.save();
  ctx.translate(-15,-20); ctx.rotate(-0.3+armSwing);
  ctx.beginPath(); ctx.roundRect(-4,0,8,20,[3]); ctx.fill();
  ctx.restore();
  ctx.save();
  ctx.translate(15,-20); ctx.rotate(0.3-armSwing);
  ctx.beginPath(); ctx.roundRect(-4,0,8,20,[3]); ctx.fill();
  // Outil dans la main droite
  if(tool==='plant'){
    ctx.fillStyle='#8B4513'; ctx.beginPath(); ctx.roundRect(-1,14,3,18,[1]); ctx.fill();
    ctx.fillStyle='#2ecc71'; ctx.beginPath(); ctx.ellipse(0,14,5,7,0,0,Math.PI*2); ctx.fill();
  } else if(tool==='cut'){
    ctx.strokeStyle='#95a5a6'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.moveTo(-3,14); ctx.lineTo(3,26); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(3,14); ctx.lineTo(-3,26); ctx.stroke();
  } else {
    ctx.fillStyle='#5dade2'; ctx.beginPath(); ctx.arc(0,24,5,0,Math.PI*2); ctx.fill();
  }
  ctx.restore();

  ctx.restore();

  // Traînée magique
  player.trail.push({x:player.x,y:player.y,alpha:0.4});
  if(player.trail.length>8) player.trail.shift();
  player.trail.forEach((p,i)=>{
    ctx.globalAlpha=(i/player.trail.length)*p.alpha*0.5*(player.isMoving?1:0);
    ctx.fillStyle='rgba(180,150,255,0.6)';
    const r=(i/player.trail.length)*6;
    ctx.beginPath(); ctx.arc(p.x,p.y-5,r,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;
}

// ── Lucioles ──
function drawFireflies() {
  if (seasonIdx!==1 && seasonIdx!==0) return; // printemps/été uniquement
  fireflies.forEach(f=>{
    f.phase+=f.speed*0.04;
    f.x=f.ox+Math.cos(f.phase)*50;
    f.y=f.oy+Math.sin(f.phase*0.7)*30;
    const glow=Math.abs(Math.sin(f.phase*2));
    const g=ctx.createRadialGradient(f.x,f.y,0,f.x,f.y,f.r*6);
    g.addColorStop(0,`rgba(200,255,180,${glow*0.9})`);
    g.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=g;
    ctx.beginPath(); ctx.arc(f.x,f.y,f.r*6,0,Math.PI*2); ctx.fill();
    ctx.fillStyle=`rgba(240,255,220,${glow})`;
    ctx.beginPath(); ctx.arc(f.x,f.y,f.r,0,Math.PI*2); ctx.fill();
  });
}

// ── Neige hiver ──
let snowflakes=[];
function initSnow(){
  snowflakes=[];
  for(let i=0;i<120;i++) snowflakes.push({x:Math.random()*w,y:Math.random()*h,r:1+Math.random()*2.5,vx:(Math.random()-0.5)*0.5,vy:0.3+Math.random()*0.6,alpha:0.5+Math.random()*0.5,phase:Math.random()*Math.PI*2});
}
function drawSnow(){
  snowflakes.forEach(s=>{
    s.phase+=0.02; s.x+=s.vx+Math.sin(s.phase)*0.4+wind*3; s.y+=s.vy;
    if(s.y>h) s.y=0; if(s.x>w) s.x=0; if(s.x<0) s.x=w;
    ctx.globalAlpha=s.alpha;
    ctx.fillStyle='#e8f4fd';
    ctx.beginPath(); ctx.arc(s.x,s.y,s.r,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;
}

// ── Loop principale ──
function loop() {
  time+=0.016;
  wind=Math.sin(time*0.55)*0.6+Math.sin(time*1.2)*0.25;

  // Input
  player.isMoving=false;
  if(keys['KeyW']||keys['ArrowUp']){player.vy-=player.speed*0.6;player.isMoving=true;}
  if(keys['KeyS']||keys['ArrowDown']){player.vy+=player.speed*0.6;player.isMoving=true;}
  if(keys['KeyA']||keys['ArrowLeft']){player.vx-=player.speed;player.dir=-1;player.isMoving=true;}
  if(keys['KeyD']||keys['ArrowRight']){player.vx+=player.speed;player.dir=1;player.isMoving=true;}
  player.vx*=player.friction; player.vy*=player.friction;
  player.x+=player.vx; player.y+=player.vy;
  player.x=Math.max(30,Math.min(w-30,player.x));
  player.y=Math.max(getHorizon()+20,Math.min(h-10,player.y));

  // Nuages
  clouds.forEach(c=>{c.x+=c.speed*(1+wind*0.3); if(c.x>w+c.r*2) c.x=-c.r*2;});
  // Oiseaux
  birds.forEach(b=>{
    b.wing+=0.15*b.wingDir; if(Math.abs(b.wing)>1) b.wingDir*=-1;
    b.x+=b.vx; b.vy=Math.sin(time*0.5+b.x*0.01)*0.2;b.y+=b.vy;
    if(b.x>w+20) b.x=-20;
    if(b.y<h*0.03) b.y=h*0.03; if(b.y>h*0.3) b.y=h*0.3;
  });
  // Particules
  particles=particles.filter(p=>{
    p.x+=p.vx+wind*1.5; p.y+=p.vy; p.alpha-=0.012; p.rot+=p.rotV; p.life-=0.012;
    return p.alpha>0;
  });
  // Gouttes
  waterDrops=waterDrops.filter(d=>{
    d.y+=d.vy; d.alpha-=0.03; return d.alpha>0;
  });

  const cfg=SEASON_CFG[SEASONS[seasonIdx]];

  // ── SKY ──
  ctx.clearRect(0,0,w,h);
  const sky=ctx.createLinearGradient(0,0,0,getHorizon()*1.1);
  sky.addColorStop(0,cfg.skyTop); sky.addColorStop(1,cfg.skyBot);
  ctx.fillStyle=sky; ctx.fillRect(0,0,w,h*0.5);

  drawSun(cfg);
  clouds.forEach(drawCloud);

  // Oiseaux
  birds.forEach(b=>{
    ctx.save(); ctx.translate(b.x,b.y); ctx.scale(b.scale,b.scale);
    ctx.strokeStyle='rgba(30,30,30,0.7)'; ctx.lineWidth=1.5; ctx.lineCap='round';
    ctx.beginPath(); ctx.moveTo(-12,0); ctx.quadraticCurveTo(-6,-5*b.wing,0,0); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(12,0);  ctx.quadraticCurveTo(6,-5*b.wing,0,0);  ctx.stroke();
    ctx.restore();
  });

  // ── GROUND ROWS ──
  const playerRow=getRow(player.y);
  for(let r=0;r<ROWS;r++){
    const rowY=getY(r);
    const nextY=r<ROWS-1?getY(r+1):h+2;

    // Sol
    const gl=ctx.createLinearGradient(0,rowY,0,nextY);
    const s=cfg.groundS+r*1.5, l=cfg.groundL+r*1.8;
    const hue=seasonIdx===0||seasonIdx===1?112:seasonIdx===2?28:210;
    gl.addColorStop(0,`hsl(${hue},${s}%,${l}%)`);
    gl.addColorStop(1,`hsl(${hue},${s+2}%,${l+2}%)`);
    ctx.fillStyle=gl; ctx.fillRect(0,rowY,w,nextY-rowY+2);

    // Brume de profondeur (rows lointaines)
    if(r<3){
      const fogAlpha=(1-(r/3))*0.35;
      ctx.fillStyle=cfg.fogColor+fogAlpha+')';
      ctx.fillRect(0,rowY,w,nextY-rowY);
    }

    // Herbe
    blades.filter(b=>b.row===r).forEach(b=>{
      const sway=Math.sin(time*1.8+b.offset)*8*b.sc+wind*22*b.sc;
      ctx.beginPath(); ctx.moveTo(b.x,b.y);
      ctx.quadraticCurveTo(b.x+wind*6,b.y-b.h*0.5,b.x+sway,b.y-b.h);
      ctx.strokeStyle=b.color; ctx.lineWidth=b.w; ctx.lineCap='round'; ctx.stroke();
    });

    // Arbres de ce rang
    trees.filter(t2=>t2.row===r).forEach(t2=>drawTree(t2,cfg));

    // Fleurs
    flowers.filter(f=>f.row===r).forEach(f=>{
      // Flétrissement progressif sans eau
      if(f.watered<=0 && Math.random()<0.0002) f.wilt=Math.min(1,f.wilt+0.01);
      drawFlower(f);
    });

    // Personnage
    if(r===playerRow) drawPlayer(getScale(player.y));
  }

  // Lucioles (par-dessus)
  drawFireflies();

  // Neige hiver
  if(seasonIdx===3) drawSnow();

  // Particules feuilles/pétales
  particles.forEach(p=>{
    ctx.save(); ctx.globalAlpha=p.alpha;
    ctx.translate(p.x,p.y); ctx.rotate(p.rot);
    ctx.fillStyle=p.color;
    ctx.beginPath();
    if(seasonIdx===3){
      ctx.arc(0,0,p.size/2,0,Math.PI*2); // flocon
    } else {
      ctx.ellipse(0,0,p.size,p.size*0.5,0,0,Math.PI*2); // feuille/pétale
    }
    ctx.fill(); ctx.restore();
  });

  // Gouttes d'eau
  waterDrops.forEach(d=>{
    ctx.globalAlpha=d.alpha;
    ctx.fillStyle='rgba(100,180,255,0.8)';
    ctx.beginPath(); ctx.ellipse(d.x,d.y,d.r,d.r*1.5,0,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;

  // Curseur ciseau
  if(tool==='cut'&&mouse){
    ctx.font='28px serif'; ctx.fillText('✂️',mouse.x-10,mouse.y+10);
  }

  requestAnimationFrame(loop);
}

let mouse=null;
canvas.addEventListener('mousemove',e=>mouse={x:e.clientX,y:e.clientY});
canvas.addEventListener('mousedown',e=>{
  if(e.clientY<getHorizon()) return;
  if(tool==='plant') createFlower(e.clientX,e.clientY);
  else if(tool==='cut') flowers=flowers.filter(f=>Math.hypot(f.x-e.clientX,(f.y-f.h/2)-e.clientY)>40);
  else {
    // Arroser — la fleur la plus proche
    flowers.forEach(f=>{
      if(Math.hypot(f.x-e.clientX,(f.y-f.h)-e.clientY)<60) { f.watered=120; }
    });
  }
});

window.addEventListener('resize',()=>{init();initSnow();});
init(); initSnow(); loop();
</script>
