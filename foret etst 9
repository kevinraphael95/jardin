<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>ForestSimulator - Expert Flora</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { margin: 0; overflow: hidden; background: #000; cursor: crosshair; }
        #ui-stats {
            position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
            width: 500px; display: flex; flex-direction: column; gap: 6px; pointer-events: none;
        }
        .bar-bg { width: 100%; height: 6px; background: rgba(0,0,0,0.8); border: 1px solid rgba(255, 255, 255, 0.1); }
        .bar-fill { height: 100%; transition: width 0.3s; }
        #hp { background: #911; } #mp { background: #119; } #sp { background: #191; }
        #top-ui { position: absolute; top: 20px; left: 20px; color: #f0e6d2; font-family: 'Cinzel'; text-shadow: 2px 2px 5px #000; }
    </style>
</head>
<body>

<div id="top-ui"><h2>FOREST SIMULATOR</h2><p>Végétation Dense & Multi-Dimensions</p></div>
<div id="ui-stats">
    <div class="bar-bg"><div id="mp" class="bar-fill" style="width:100%"></div></div>
    <div class="bar-bg"><div id="hp" class="bar-fill" style="width:100%"></div></div>
    <div class="bar-bg"><div id="sp" class="bar-fill" style="width:100%"></div></div>
</div>

<script type="importmap">
    { "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }
</script>

<script type="module">
    import * as THREE from 'three';
    import { PointerLockControls } from 'https://unpkg.com/three@0.160.0/examples/jsm/controls/PointerLockControls.js';

    const scene = new THREE.Scene();
    let currentDim = 0;
    const dimColors = [0x2a3a4a, 0x4a1a3a]; // Dim 0: Bleu/Vert, Dim 1: Violet/Rouge
    scene.background = new THREE.Color(dimColors[0]);
    scene.fog = new THREE.FogExp2(dimColors[0], 0.006);

    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 4000);
    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    document.body.appendChild(renderer.domElement);

    scene.add(new THREE.HemisphereLight(0xffffff, 0x080808, 0.8));
    const sun = new THREE.DirectionalLight(0xfff0dd, 2.5);
    sun.position.set(100, 300, 100);
    sun.castShadow = true;
    scene.add(sun);

    // --- TERRAIN ---
    const groundGeo = new THREE.PlaneGeometry(1000, 1000, 100, 100);
    const pos = groundGeo.attributes.position.array;
    for(let i=0; i<pos.length; i+=3) {
        pos[i+2] = Math.sin(pos[i]*0.03) * Math.cos(pos[i+1]*0.03) * 10;
    }
    groundGeo.computeVertexNormals();
    const groundMat = new THREE.MeshStandardMaterial({ color: 0x1a2b10, roughness: 1 });
    const ground = new THREE.Mesh(groundGeo, groundMat);
    ground.rotation.x = -Math.PI/2;
    ground.receiveShadow = true;
    scene.add(ground);
    ground.updateMatrixWorld();

    const raycaster = new THREE.Raycaster(new THREE.Vector3(), new THREE.Vector3(0, -1, 0));
    function findY(x, z) {
        raycaster.ray.origin.set(x, 100, z);
        const hit = raycaster.intersectObject(ground);
        return hit.length > 0 ? hit[0].point.y : 0;
    }

    const windObjs = [];
    const colliders = [];
    const trees = [];
    const flowers = [];

    // --- PLATEFORME & PORTE ---
    const portalData = { x: 15, z: 15, active: true };
    function createPortal(px, pz) {
        const group = new THREE.Group();
        const y = findY(px, pz);
        
        // Escalier & Plateforme
        for(let i=0; i<6; i++) {
            const step = new THREE.Mesh(new THREE.BoxGeometry(4, 0.8, 4), new THREE.MeshStandardMaterial({color: 0x333333}));
            step.position.set(0, (i * 0.4), i * 2);
            group.add(step);
        }
        const platform = new THREE.Mesh(new THREE.BoxGeometry(8, 0.5, 8), new THREE.MeshStandardMaterial({color: 0x222222}));
        platform.position.set(0, 2.2, -2);
        group.add(platform);

        // Porte (Cadre)
        const frameMat = new THREE.MeshStandardMaterial({color: 0x000000, emissive: 0x00ffff});
        const door = new THREE.Mesh(new THREE.BoxGeometry(3, 5, 0.2), new THREE.MeshStandardMaterial({color: 0x00ffff, transparent: true, opacity: 0.3}));
        door.position.set(0, 4.7, -2);
        group.add(door);
        
        group.position.set(px, y, pz);
        scene.add(group);
        return { x: px, z: pz + (currentDim === 0 ? -2 : -2), y: y + 2.2 };
    }
    const portalPos = createPortal(15, 15);

    // --- LUCIOLES ---
    const firefliesGeo = new THREE.BufferGeometry();
    const firefliesCount = 200;
    const firefliesPos = new Float32Array(firefliesCount * 3);
    for(let i=0; i<firefliesCount*3; i+=3) {
        firefliesPos[i] = (Math.random()-0.5) * 400;
        firefliesPos[i+1] = Math.random() * 20;
        firefliesPos[i+2] = (Math.random()-0.5) * 400;
    }
    firefliesGeo.setAttribute('position', new THREE.BufferAttribute(firefliesPos, 3));
    const firefliesMat = new THREE.PointsMaterial({ color: 0xaaff00, size: 0.5, transparent: true });
    const fireflies = new THREE.Points(firefliesGeo, firefliesMat);
    scene.add(fireflies);

    // --- FLORE (Ton code original) ---
    function spawnFlower(x, z) {
        const y = findY(x, z);
        const flowerGroup = new THREE.Group();
        const stem = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.03, 0.8), new THREE.MeshStandardMaterial({color: 0x2d4c1e}));
        stem.position.y = 0.4;
        flowerGroup.add(stem);
        const head = new THREE.Mesh(new THREE.SphereGeometry(0.12, 6, 6), new THREE.MeshStandardMaterial({color: 0xffffff}));
        head.position.y = 0.8;
        flowerGroup.add(head);
        flowerGroup.position.set(x, y, z);
        scene.add(flowerGroup);
        flowers.push(head);
        windObjs.push({ mesh: flowerGroup, phase: Math.random() * 5, speed: 2, amp: 0.05 });
    }

    function spawnTree(x, z) {
        if(Math.abs(x-15) < 10 && Math.abs(z-15) < 10) return;
        const y = findY(x, z);
        const treeGroup = new THREE.Group();
        const height = 15 + Math.random() * 20;
        const trunkThickness = 0.8 + Math.random() * 0.8;
        const trunk = new THREE.Mesh(new THREE.CylinderGeometry(trunkThickness * 0.4, trunkThickness, height, 8), new THREE.MeshStandardMaterial({color: 0x1a0f0a}));
        trunk.position.y = height / 2 - 0.5;
        treeGroup.add(trunk);
        const leafColor = 0x0a1a0a;
        const layerCount = 6;
        for(let i=0; i<layerCount; i++) {
            const ratio = i / layerCount;
            const size = (1 - ratio) * (trunkThickness * 8) + 1;
            const layer = new THREE.Mesh(new THREE.ConeGeometry(size, 6, 8), new THREE.MeshStandardMaterial({color: leafColor}));
            layer.position.y = height * 0.3 + (ratio * height * 0.8);
            treeGroup.add(layer);
            trees.push(layer);
            windObjs.push({ mesh: layer, phase: Math.random() * 5, speed: 0.5, amp: 0.02 });
        }
        treeGroup.position.set(x, y, z);
        scene.add(treeGroup);
        colliders.push({ x: x, z: z, r: trunkThickness + 0.5 });
    }

    for(let i=0; i<120; i++) spawnTree((Math.random()-0.5)*600, (Math.random()-0.5)*600);
    for(let i=0; i<400; i++) spawnFlower((Math.random()-0.5)*300, (Math.random()-0.5)*300);

    // --- CONTROLES ---
    const controls = new PointerLockControls(camera, document.body);
    document.body.addEventListener('click', () => controls.lock());
    let velocity = new THREE.Vector3(), keys = { z:false, s:false, q:false, d:false };
    document.addEventListener('keydown', (e) => { if(keys.hasOwnProperty(e.key.toLowerCase())) keys[e.key.toLowerCase()] = true; });
    document.addEventListener('keyup', (e) => { if(keys.hasOwnProperty(e.key.toLowerCase())) keys[e.key.toLowerCase()] = false; });

    function changeDimension() {
        currentDim = currentDim === 0 ? 1 : 0;
        const newColor = dimColors[currentDim];
        scene.background.set(newColor);
        scene.fog.color.set(newColor);
        
        // Changement excentrique : les arbres deviennent rouges ou violets
        trees.forEach(t => t.material.color.set(currentDim === 0 ? 0x0a1a0a : 0x660022));
        groundMat.color.set(currentDim === 0 ? 0x1a2b10 : 0x221133);
        firefliesMat.color.set(currentDim === 0 ? 0xaaff00 : 0xff00ff);
    }

    function animate(time) {
        requestAnimationFrame(animate);
        const t = time * 0.001;

        windObjs.forEach(obj => { obj.mesh.rotation.z = Math.sin(t * obj.speed + obj.phase) * obj.amp; });
        
        // Animation lucioles
        const fPos = fireflies.geometry.attributes.position.array;
        for(let i=0; i<fPos.length; i+=3) {
            fPos[i+1] += Math.sin(t + i) * 0.01;
        }
        fireflies.geometry.attributes.position.needsUpdate = true;

        if(controls.isLocked) {
            const f = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion);
            const r = new THREE.Vector3(1,0,0).applyQuaternion(camera.quaternion);
            f.y = 0; r.y = 0; f.normalize(); r.normalize();

            if(keys.z) velocity.add(f.multiplyScalar(0.02));
            if(keys.s) velocity.sub(f.multiplyScalar(0.02));
            if(keys.q) velocity.sub(r.multiplyScalar(0.02));
            if(keys.d) velocity.add(r.multiplyScalar(0.02));

            velocity.multiplyScalar(0.9);

            let nX = camera.position.x + velocity.x;
            let nZ = camera.position.z + velocity.z;

            // Collision Portail (Changement de dimension)
            const distPortal = Math.sqrt((nX - portalPos.x)**2 + (nZ - (portalPos.z-2))**2);
            if(distPortal < 1.5 && Math.abs(camera.position.y - (portalPos.y + 1.8)) < 2) {
                changeDimension();
                camera.position.x -= 5; // Petit recul pour éviter la boucle infinie
            }

            colliders.forEach(c => {
                const dx = nX - c.x, dz = nZ - c.z;
                const dist = Math.sqrt(dx*dx + dz*dz);
                if(dist < c.r) {
                    const angle = Math.atan2(dz, dx);
                    nX = c.x + Math.cos(angle) * c.r;
                    nZ = c.z + Math.sin(angle) * c.r;
                }
            });

            camera.position.x = nX;
            camera.position.z = nZ;

            // Hauteur dynamique (Gestion plateforme sommaire)
            let targetY = findY(camera.position.x, camera.position.z);
            if(Math.abs(camera.position.x - portalPos.x) < 4 && Math.abs(camera.position.z - portalPos.z) < 8) {
                // Si proche plateforme, on ajuste la hauteur pour "monter"
                if(camera.position.z < 20 && camera.position.z > 10) targetY = Math.max(targetY, portalPos.y - 1.5);
            }
            
            camera.position.y += ((targetY + 1.8) - camera.position.y) * 0.1;
        }

        renderer.render(scene, camera);
    }
    animate(0);
</script>
</body>
</html>
